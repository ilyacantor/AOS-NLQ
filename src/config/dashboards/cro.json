{
  "id": "cro-dashboard-v1",
  "persona": "CRO",
  "name": "Revenue Overview",
  "description": "Sales and revenue performance dashboard",
  "refreshInterval": 300,
  "timeRangeDefault": "YTD",
  "timeRangeOptions": ["MTD", "QTD", "YTD", "L12M", "Custom"],

  "layout": {
    "type": "grid",
    "columns": 12,
    "rowHeight": 80
  },

  "tiles": [
    {
      "id": "kpi-bookings",
      "type": "kpi",
      "position": { "x": 0, "y": 0, "w": 3, "h": 2 },
      "config": {
        "label": "Bookings",
        "query": "What is total bookings year to date?",
        "clickQuery": "What is driving bookings this period?",
        "format": "currency",
        "showSparkline": true,
        "showTrend": true,
        "trendQuery": "Show monthly bookings for the last 12 months"
      }
    },
    {
      "id": "kpi-pipeline",
      "type": "kpi",
      "position": { "x": 3, "y": 0, "w": 3, "h": 2 },
      "config": {
        "label": "Pipeline",
        "query": "What is total pipeline year to date?",
        "clickQuery": "What is in the sales pipeline?",
        "format": "currency",
        "showSparkline": true,
        "showTrend": true,
        "trendQuery": "Show monthly pipeline for the last 12 months"
      }
    },
    {
      "id": "kpi-win-rate",
      "type": "kpi",
      "position": { "x": 6, "y": 0, "w": 3, "h": 2 },
      "config": {
        "label": "Win Rate",
        "query": "What is our win rate year to date?",
        "clickQuery": "What factors are affecting win rate?",
        "format": "percentage",
        "showSparkline": true,
        "showTrend": true,
        "trendQuery": "Show monthly win rate for the last 12 months"
      }
    },
    {
      "id": "kpi-nrr",
      "type": "kpi",
      "position": { "x": 9, "y": 0, "w": 3, "h": 2 },
      "config": {
        "label": "NRR",
        "query": "What is our net revenue retention year to date?",
        "clickQuery": "What drives changes in NRR?",
        "format": "percentage",
        "showSparkline": true,
        "showTrend": true,
        "trendQuery": "Show monthly NRR for the last 12 months"
      }
    },
    {
      "id": "chart-pipeline-velocity",
      "type": "chart",
      "position": { "x": 0, "y": 2, "w": 8, "h": 4 },
      "config": {
        "chartType": "waterfall",
        "title": "Pipeline Velocity Funnel",
        "query": "Show pipeline stages with conversion rates",
        "clickQuery": "Explain the conversion rate changes in {stage}",
        "colorScheme": "financial",
        "showLegend": true,
        "showLabels": true,
        "enableDrilldown": true
      }
    },
    {
      "id": "panel-revenue-insights",
      "type": "insights",
      "position": { "x": 8, "y": 2, "w": 4, "h": 4 },
      "config": {
        "title": "AI Revenue Insights",
        "query": "What are the top 5 revenue insights and anomalies this period?",
        "refreshInterval": 600,
        "maxItems": 5,
        "showSeverity": true,
        "showActionable": true,
        "categories": ["bookings", "pipeline", "win-rate", "churn", "quota"]
      }
    },
    {
      "id": "chart-churn-radar",
      "type": "chart",
      "position": { "x": 0, "y": 6, "w": 4, "h": 3 },
      "config": {
        "chartType": "horizontalBar",
        "title": "Churn Radar",
        "query": "Show churn by segment or account risk",
        "clickQuery": "Show detailed churn analysis for {segment}",
        "colorScheme": "categorical",
        "showLegend": false,
        "showLabels": true,
        "enableDrilldown": true
      }
    },
    {
      "id": "chart-win-rate-segment",
      "type": "chart",
      "position": { "x": 4, "y": 6, "w": 4, "h": 3 },
      "config": {
        "chartType": "bar",
        "title": "Win Rate by Segment",
        "query": "Show win rates by market segment",
        "clickQuery": "Show detailed win rate analysis for {segment}",
        "colorScheme": "categorical",
        "showLegend": false,
        "showLabels": true,
        "enableDrilldown": true
      }
    },
    {
      "id": "chart-quota-attainment",
      "type": "chart",
      "position": { "x": 8, "y": 6, "w": 4, "h": 3 },
      "config": {
        "chartType": "stackedBar",
        "title": "Quota Attainment",
        "query": "Show quota attainment by rep",
        "clickQuery": "Show detailed quota breakdown for {rep}",
        "colorScheme": "diverging",
        "showLegend": true,
        "showLabels": true,
        "enableDrilldown": true
      }
    },
    {
      "id": "nlq-input",
      "type": "nlq",
      "position": { "x": 0, "y": 9, "w": 12, "h": 1 },
      "config": {
        "placeholder": "Ask a sales question...",
        "suggestedQueries": [
          "What is our customer acquisition cost trend?",
          "Show sales pipeline forecast for next quarter",
          "What is our churn rate by customer segment?",
          "Compare win rates across regions",
          "Show quota attainment by sales rep"
        ],
        "showHistory": true,
        "maxHistoryItems": 10,
        "enableVoice": false,
        "autoComplete": true
      }
    }
  ]
}
