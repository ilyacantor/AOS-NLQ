{
  "id": "chro-dashboard-v1",
  "persona": "CHRO",
  "name": "People Overview",
  "description": "Executive HR and workforce dashboard",
  "refreshInterval": 300,
  "timeRangeDefault": "YTD",
  "timeRangeOptions": ["MTD", "QTD", "YTD", "L12M", "Custom"],

  "layout": {
    "type": "grid",
    "columns": 12,
    "rowHeight": 80
  },

  "tiles": [
    {
      "id": "kpi-headcount",
      "type": "kpi",
      "position": { "x": 0, "y": 0, "w": 3, "h": 2 },
      "config": {
        "label": "Total Headcount",
        "query": "What is total headcount?",
        "clickQuery": "Show headcount breakdown by department",
        "format": "number",
        "showSparkline": true,
        "showTrend": true,
        "trendQuery": "Show quarterly headcount for the last 4 quarters"
      }
    },
    {
      "id": "kpi-attrition",
      "type": "kpi",
      "position": { "x": 3, "y": 0, "w": 3, "h": 2 },
      "config": {
        "label": "Attrition Rate",
        "query": "What is the attrition rate?",
        "clickQuery": "What is driving attrition this period?",
        "format": "percentage",
        "showSparkline": true,
        "showTrend": true,
        "trendQuery": "Show quarterly attrition rate for the last 4 quarters"
      }
    },
    {
      "id": "kpi-hires",
      "type": "kpi",
      "position": { "x": 6, "y": 0, "w": 3, "h": 2 },
      "config": {
        "label": "New Hires",
        "query": "How many new hires this period?",
        "clickQuery": "Show new hire breakdown by department",
        "format": "number",
        "showSparkline": true,
        "showTrend": true,
        "trendQuery": "Show quarterly new hires for the last 4 quarters"
      }
    },
    {
      "id": "kpi-growth",
      "type": "kpi",
      "position": { "x": 9, "y": 0, "w": 3, "h": 2 },
      "config": {
        "label": "HC Growth Rate",
        "query": "What is employee growth rate?",
        "clickQuery": "What departments are growing fastest?",
        "format": "percentage",
        "showSparkline": true,
        "showTrend": true,
        "trendQuery": "Show quarterly employee growth rate for the last 4 quarters"
      }
    },
    {
      "id": "chart-headcount-dept",
      "type": "chart",
      "position": { "x": 0, "y": 2, "w": 6, "h": 2 },
      "config": {
        "chartType": "horizontalBar",
        "title": "Headcount by Department",
        "query": "Show headcount by department",
        "clickQuery": "Show details for {department} team",
        "colorScheme": "categorical",
        "showLegend": false,
        "showLabels": true,
        "enableDrilldown": true
      }
    },
    {
      "id": "panel-insights",
      "type": "insights",
      "position": { "x": 6, "y": 2, "w": 6, "h": 2 },
      "config": {
        "title": "HR Insights",
        "query": "What are the top 5 HR and workforce insights this period?",
        "refreshInterval": 600,
        "maxItems": 5,
        "showSeverity": true,
        "showActionable": true,
        "categories": ["hiring", "retention", "turnover", "compensation", "engagement"]
      }
    },
    {
      "id": "chart-tenure",
      "type": "chart",
      "position": { "x": 0, "y": 4, "w": 4, "h": 3 },
      "config": {
        "chartType": "donut",
        "title": "Workforce by Tenure",
        "query": "Show employee breakdown by tenure band",
        "clickQuery": "Show employees in {tenure} tenure band",
        "colorScheme": "categorical",
        "showLegend": true,
        "showLabels": true,
        "enableDrilldown": true
      }
    },
    {
      "id": "chart-hiring-pipeline",
      "type": "chart",
      "position": { "x": 4, "y": 4, "w": 4, "h": 3 },
      "config": {
        "chartType": "stackedBar",
        "title": "Hiring Pipeline",
        "query": "Show hiring pipeline by stage",
        "clickQuery": "Show candidates in {stage} stage",
        "colorScheme": "sequential",
        "showLegend": true,
        "showLabels": true,
        "enableDrilldown": true,
        "stages": ["Applied", "Screening", "Interview", "Offer", "Accepted"]
      }
    },
    {
      "id": "chart-turnover-trend",
      "type": "chart",
      "position": { "x": 8, "y": 4, "w": 4, "h": 3 },
      "config": {
        "chartType": "line",
        "title": "Turnover Trend",
        "query": "Show monthly turnover rate for the last 12 months",
        "clickQuery": "Show turnover details for {month}",
        "colorScheme": "diverging",
        "showLegend": false,
        "showLabels": false,
        "enableDrilldown": true
      }
    },
    {
      "id": "nlq-input",
      "type": "nlq",
      "position": { "x": 0, "y": 7, "w": 12, "h": 1 },
      "config": {
        "placeholder": "Ask an HR question...",
        "suggestedQueries": [
          "What is our PTO policy?",
          "How much 401k match do we offer?",
          "Who is the CEO?",
          "What are the company holidays?",
          "What is our parental leave policy?",
          "How do I request time off?",
          "What benefits do we offer?"
        ],
        "showHistory": true,
        "maxHistoryItems": 10,
        "enableVoice": false,
        "autoComplete": true
      }
    }
  ]
}
