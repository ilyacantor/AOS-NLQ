{
  "id": "coo-dashboard-v1",
  "persona": "COO",
  "name": "Operations Overview",
  "description": "Operational metrics and efficiency dashboard",
  "refreshInterval": 300,
  "timeRangeDefault": "YTD",
  "timeRangeOptions": ["MTD", "QTD", "YTD", "L12M", "Custom"],

  "layout": {
    "type": "grid",
    "columns": 12,
    "rowHeight": 80
  },

  "tiles": [
    {
      "id": "kpi-headcount",
      "type": "kpi",
      "position": { "x": 0, "y": 0, "w": 3, "h": 2 },
      "config": {
        "label": "Headcount",
        "query": "What is the current total headcount?",
        "clickQuery": "Show headcount breakdown by department and function",
        "format": "number",
        "showSparkline": true,
        "showTrend": true,
        "trendQuery": "Show monthly headcount for the last 12 months"
      }
    },
    {
      "id": "kpi-magic-number",
      "type": "kpi",
      "position": { "x": 3, "y": 0, "w": 3, "h": 2 },
      "config": {
        "label": "Magic Number",
        "query": "What is the current magic number (ARR growth / S&M spend)?",
        "clickQuery": "What is driving changes in our magic number?",
        "format": "number",
        "showSparkline": true,
        "showTrend": true,
        "trendQuery": "Show magic number trend for the last 12 months"
      }
    },
    {
      "id": "kpi-ltv-cac",
      "type": "kpi",
      "position": { "x": 6, "y": 0, "w": 3, "h": 2 },
      "config": {
        "label": "LTV/CAC",
        "query": "What is the current LTV to CAC ratio?",
        "clickQuery": "Show LTV and CAC components",
        "format": "ratio",
        "showSparkline": true,
        "showTrend": true,
        "trendQuery": "Show LTV/CAC ratio trend for the last 12 months"
      }
    },
    {
      "id": "kpi-nps",
      "type": "kpi",
      "position": { "x": 9, "y": 0, "w": 3, "h": 2 },
      "config": {
        "label": "NPS",
        "query": "What is the current Net Promoter Score?",
        "clickQuery": "Show NPS drivers and detractors",
        "format": "number",
        "showSparkline": true,
        "showTrend": true,
        "trendQuery": "Show NPS trend for the last 12 months"
      }
    },
    {
      "id": "chart-headcount-by-function",
      "type": "chart",
      "position": { "x": 0, "y": 2, "w": 8, "h": 4 },
      "config": {
        "chartType": "horizontalBar",
        "title": "Headcount by Function",
        "query": "Show headcount by department",
        "clickQuery": "Show detailed headcount breakdown for {department}",
        "colorScheme": "categorical",
        "showLegend": false,
        "showLabels": true,
        "enableDrilldown": true
      }
    },
    {
      "id": "panel-operational-insights",
      "type": "insights",
      "position": { "x": 8, "y": 2, "w": 4, "h": 4 },
      "config": {
        "title": "AI Operational Insights",
        "query": "What are the top 5 operational insights and efficiency opportunities this period?",
        "refreshInterval": 600,
        "maxItems": 5,
        "showSeverity": true,
        "showActionable": true,
        "categories": ["headcount", "utilization", "efficiency", "service-quality", "performance"]
      }
    },
    {
      "id": "chart-utilization-rates",
      "type": "chart",
      "position": { "x": 0, "y": 6, "w": 4, "h": 3 },
      "config": {
        "chartType": "bar",
        "title": "Utilization Rates",
        "query": "Show utilization rates by team",
        "clickQuery": "Show detailed utilization metrics for {team}",
        "colorScheme": "categorical",
        "showLegend": false,
        "showLabels": true,
        "enableDrilldown": true
      }
    },
    {
      "id": "chart-service-metrics",
      "type": "chart",
      "position": { "x": 4, "y": 6, "w": 4, "h": 3 },
      "config": {
        "chartType": "line",
        "title": "Service Metrics",
        "query": "Show implementation time and time to value trends",
        "clickQuery": "Explain changes in {metric}",
        "colorScheme": "categorical",
        "showLegend": true,
        "showLabels": true,
        "enableDrilldown": true
      }
    },
    {
      "id": "chart-csat-trend",
      "type": "chart",
      "position": { "x": 8, "y": 6, "w": 4, "h": 3 },
      "config": {
        "chartType": "line",
        "title": "CSAT Trend",
        "query": "Show customer satisfaction score trend",
        "clickQuery": "Show CSAT details for {period}",
        "colorScheme": "categorical",
        "showLegend": true,
        "showLabels": true,
        "enableDrilldown": true
      }
    },
    {
      "id": "nlq-input",
      "type": "nlq",
      "position": { "x": 0, "y": 9, "w": 12, "h": 1 },
      "config": {
        "placeholder": "Ask an operational question...",
        "suggestedQueries": [
          "What is our headcount by department?",
          "Show team utilization rates this quarter",
          "What is the current NPS and trend?",
          "Show customer satisfaction by service line",
          "What is our magic number and LTV/CAC ratio?"
        ],
        "showHistory": true,
        "maxHistoryItems": 10,
        "enableVoice": false,
        "autoComplete": true
      }
    }
  ]
}
