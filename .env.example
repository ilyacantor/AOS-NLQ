# AOS-NLQ Environment Configuration
# Copy this file to .env and fill in your values

# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=your-api-key-here

# Optional: Reference date for relative period resolution (defaults to today)
# Format: YYYY-MM-DD
# NLQ_REFERENCE_DATE=2026-01-27

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Optional: API host and port
# API_HOST=0.0.0.0
# API_PORT=8000

# =============================================================================
# RAG Cache Configuration (Optional)
# =============================================================================

# Pinecone for vector storage (required for RAG cache)
# PINECONE_API_KEY=your-pinecone-api-key
# PINECONE_INDEX=aos-nlq
# PINECONE_NAMESPACE=nlq-query-cache

# OpenAI for embeddings (required for RAG cache)
# OPENAI_API_KEY=your-openai-api-key

# Cache similarity thresholds (0.0-1.0)
# CACHE_THRESHOLD_EXACT=0.95
# CACHE_THRESHOLD_HIGH=0.92
# CACHE_THRESHOLD_PARTIAL=0.85

# Enable/disable RAG cache (default: true if keys are set)
# RAG_CACHE_ENABLED=true

# =============================================================================
# Supabase Configuration (Optional - for persistent learning log)
# =============================================================================

# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-supabase-anon-key
