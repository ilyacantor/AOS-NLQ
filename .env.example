# =============================================================================
# AOS-NLQ Environment Variables
# Copy to .env and fill in values. All secrets should be set via Render dashboard.
# =============================================================================

# --- Required ---
ANTHROPIC_API_KEY=

# --- DCL Integration ---
DCL_API_URL=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_API_URL=
SUPABASE_KEY=

# --- RAG Cache (Pinecone + OpenAI embeddings) ---
PINECONE_API_KEY=
PINECONE_INDEX=aos-nlq
PINECONE_NAMESPACE=nlq-query-cache
OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=

# --- Cache tuning ---
RAG_CACHE_ENABLED=true
CACHE_THRESHOLD_EXACT=0.95
CACHE_THRESHOLD_HIGH=0.92
CACHE_THRESHOLD_PARTIAL=0.85

# --- App config (NLQ_ prefix → pydantic-settings) ---
NLQ_REFERENCE_DATE=
NLQ_LOG_LEVEL=INFO
NLQ_API_HOST=0.0.0.0
NLQ_API_PORT=8000
AOS_TENANT_ID=
NLQ_FACT_BASE_PATH=data/fact_base.json
NLQ_TEST_QUESTIONS_PATH=data/nlq_test_questions.json

# --- CORS ---
CORS_ORIGINS=http://localhost:5000,http://localhost:3000,http://localhost:8000
