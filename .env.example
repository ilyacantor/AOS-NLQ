# AOS-NLQ Environment Configuration
# Copy this file to .env and fill in your values

# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=your-api-key-here

# Optional: Reference date for relative period resolution (defaults to today)
# Format: YYYY-MM-DD
# NLQ_REFERENCE_DATE=2026-01-27

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Optional: API host and port
# API_HOST=0.0.0.0
# API_PORT=8000
