      "root_cause": {
        "type": "timing",
        "explanation": "SAP ERP recognizes revenue on invoice date; Salesforce CRM records it at deal close. The $2.2M gap represents deals closed in CRM but not yet invoiced in ERP.",
        "recommendation": "Trust ERP (SAP) for recognized revenue. CRM figure includes unbilled deals."
      },
      "trust_recommendation": {
